FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 750;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 750;
    }

    outlet
    {
        type            zeroGradient;
    }

    

    bottom_1
    {
        type            zeroGradient;
    }
	bottom_2
    {
        type            zeroGradient;
    }
	step
    {
        type            zeroGradient;
    }

    top
    {
        type            zeroGradient;
    }
    /*{
    	type		waveTransmissive;
    	field		p;
    	phi		phi;
    	rho		rho;
    	psi		thermo:psi;
    	gamma		1.4;
    	value		$internalField;
    }*/

    side
    {
        type            empty;
    }
}


