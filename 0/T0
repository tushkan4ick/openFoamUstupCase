FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      T0;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 253;

boundaryField
{
    inlet
    {
        type            zeroGradient;
    }
    outlet
    {
        type            zeroGradient;
    }
    bottom_1
    {
        type            zeroGradient;
    }
    step
    {
        type            zeroGradient;
    }
    bottom_2
    {
        type            zeroGradient;
    }
    top
    {
        type            zeroGradient;
    }
    side
    {
        type            empty;
    }
}


