FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

omegaInlet      10;

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform $omegaInlet;

boundaryField
{
	inlet
	{
		type            fixedValue;
		value           uniform $omegaInlet;
	}
	outlet
	{
		type            zeroGradient;
	}
	top
	{
        type            zeroGradient;
    }
	bottom_1
	{
       type            omegaWallFunction;
       value           uniform $omegaInlet;
    }

    bottom_2
    {
        type            omegaWallFunction;
        value           uniform $omegaInlet;
    }
	
    step
    {
        type            omegaWallFunction;
        value           uniform $omegaInlet;
    }

	side
    {
        type            empty;
    }

}


