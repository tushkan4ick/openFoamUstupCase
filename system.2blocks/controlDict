FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     rhoCentralFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         0.6;

deltaT          0.0001;

writeControl    adjustable;

writeInterval   0.01;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

adjustTimeStep  yes;

maxCo           0.5;

maxDeltaT       1;


functions
{
    minPressure
    {
        type            fieldMinMax;
        libs            ("libfieldFunctionObjects.so");
        enabled         true;
        writeControl    writeTime;
        mode            magnitude;
        fields          ( p );
    }
    minMaxVelocity
    {
        type            fieldMinMax;
        libs            ("libfieldFunctionObjects.so");
        enabled         true;
        writeControl    writeTime;
        mode            component;
        fields          ( U );
    }
    MachNo1
    {
        type            MachNo;
        libs            (fieldFunctionObjects);

        writeControl    writeTime;
    }
    
    ReynoldsNumber
    {
    	type            exprField;
    	libs            ("libfieldFunctionObjects.so");

   	enabled         true;
    	field           Re;
    	dimensions      [0 0 0 0 0 0 0];

    	expression      "rho*mag(U)*(T + 110)/(1.458e-06*pow(T,1.5))";

    	autowrite       true;
    	store           true;

    	executeControl  timeStep;
    	executeInterval 1;
    	writeControl    writeTime;
    }

}
