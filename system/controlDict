FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     hisa;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         1.5;

deltaT          0.05;

writeControl    adjustable;

writeInterval   0.05;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

adjustTimeStep  yes;

maxCo			500;

maxDeltaT       1;


functions
{
    /*minPressure
    {
        type            fieldMinMax;
        libs            ("libfieldFunctionObjects.so");
        enabled         true;
        writeControl    writeTime;
        mode            magnitude;
        fields          ( p );
    }

    minMaxVelocity
    {
        type            fieldMinMax;
        libs            ("libfieldFunctionObjects.so");
        enabled         true;
        writeControl    writeTime;
        mode            component;
        fields          ( U );
    }*/

    MachNo1
    {
        type            MachNo;
        libs            (fieldFunctionObjects);

        writeControl    writeTime;
    }
    
    ReynoldsNumber
    {
    	type            exprField;
    	libs            ("libfieldFunctionObjects.so");

   	    enabled         true;
    	field           Re;
    	dimensions      [0 0 0 0 0 0 0];

    	expression      "rho*mag(U)*(T + 110)*3/(1.458e-06*pow(T,1.5))";

    	autowrite       true;
    	store           true;

    	executeControl  timeStep;
    	executeInterval 1;
    	writeControl    writeTime;
    }
    
    Entropy
    {
    	type 		    exprField;
    	libs            ("libfieldFunctionObjects.so");
    	
    	enabled		    true;
    	field		    s;
    	dimensions	    [1 2 -2 -1 0 0 0];
    	
    	expression	    "1005*log(T/288)-287*log(p/101325)";
    	
    	autowrite       true;
    	store           true;

    	executeControl  timeStep;
    	executeInterval 1;
    	writeControl    writeTime;
    }

    TotalTemperature
    {
    	type            exprField;
    	libs            ("libfieldFunctionObjects.so");

   	    enabled         true;
    	field           T0;
    	dimensions      [0 0 0 1 0 0 0];

    	expression      "T*(1+0.2*pow(Ma,2))";

    	autowrite       true;
    	store           true;

    	executeControl  timeStep;
    	executeInterval 1;
    	writeControl    writeTime;
    }

    TotalEnthalpy
    {
    	type            exprField;
    	libs            ("libfieldFunctionObjects.so");

   	    enabled         true;
    	field           H0;
    	dimensions      [0 2 -2 0 0 0 0];

    	expression      "1005*T + 0.5*magSqr(U)";

    	autowrite       true;
    	store           true;

    	executeControl  timeStep;
    	executeInterval 1;
    	writeControl    writeTime;
    }

    gradP
    {
        type            grad;
        libs            (fieldFunctionObjects);
        field           p;

        writeControl    writeTime;
    }

    divU
    {
        type            div;
        libs            (fieldFunctionObjects);
        field           U;

        writeControl    writeTime;
    }

    Q
    {
        type            Q;
        libs            (fieldFunctionObjects);

        writeControl    writeTime;
    }

    wSS
    {
        type            wallShearStress;
        libs            (fieldFunctionObjects);

        writeControl    writeTime;
    }

    yPlus
    {
        type            yPlus;
        libs            (fieldFunctionObjects);

        writeControl    writeTime;
    }

}
