FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

Uinlet          (662 0 0);

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    inlet
    {
        type            fixedProfile;
        value           uniform $Uinlet;
        
        direction	(0 1 0);
        origin		0;			//сдвиг, если линия начинается не в 0
        
        profile		csvFile;
        profileCoeffs
        {
            nHeaderLine		1;
            refColumn		4;				//Столбец с координатой, с которой считываются скорости
            componentColumns    (0 1 2);			//Допускаются любые целые числа, дающие номера столбцов (Ux Uy Uz)
            separator		",";				//допускается любой, в тч несколько, по умолчанию: ","
            mergeSeparators     no;        			//для одного разделителя, если несколько, то: yes
            file        		"constant/uProfile.csv";
            outOfBounds         clamp;				//clamp - при выходе за пределы значение становится постоянным и равным значению на границе
            interpolationScheme linear;
        }
        
    }

    outlet
    {
        type            zeroGradient;
    }

    bottom
    {
        type            noSlip;
    }

    top
    {
        type            zeroGradient;
    }

    side
    {
        type            empty;
    }
}


